步骤1：从 B keystore 导出证书                                                                                                                                                                    
   
  # 导出为证书文件（公钥）                                                                                                                                                                         
  keytool -export -alias your_alias \                                                                                                                                                            
    -keystore B.keystore \
    -file certificate.crt \
    -storepass B_keystore_password

  # 或者导出为 PKCS12 格式（包含私钥）
  keytool -importkeystore \
    -srckeystore B.keystore \
    -destkeystore B.p12 \
    -deststoretype PKCS12 \
    -srcalias your_alias \
    -destalias your_alias \
    -srcstorepass B_keystore_password \
    -deststorepass B_p12_password

  步骤2：导入到 A keystore

  # 方法1：导入证书文件（只有公钥，不能签名）
  keytool -import -alias your_alias \
    -keystore A.keystore \
    -file certificate.crt \
    -storepass A_keystore_password

  # 方法2：导入 PKCS12（包含私钥，可以签名）
  keytool -importkeystore \
    -srckeystore B.p12 \
    -srcstoretype PKCS12 \
    -destkeystore A.keystore \
    -srcalias your_alias \
    -destalias your_alias \
    -srcstorepass B_p12_password \
    -deststorepass A_keystore_password

  步骤3：验证导入结果

  # 查看 A keystore 中的证书
  keytool -list -v -keystore A.keystore \
    -alias your_alias \
    -storepass A_keystore_password

  # 查看有效期
  keytool -list -v -keystore A.keystore \
    -storepass A_keystore_password | grep "Alias.*your_alias" -A 10

  完整示例脚本

  #!/bin/bash
  ALIAS="your_alias"
  B_KEYSTORE="B.keystore"
  A_KEYSTORE="A.keystore"
  B_PASSWORD="changeit"
  A_PASSWORD="changeit"

  # 1. 从 B 导出为 PKCS12
  keytool -importkeystore \
    -srckeystore $B_KEYSTORE \
    -destkeystore temp.p12 \
    -deststoretype PKCS12 \
    -srcalias $ALIAS \
    -destalias $ALIAS \
    -srcstorepass $B_PASSWORD \
    -deststorepass $B_PASSWORD

  # 2. 导入到 A（会覆盖相同 alias）
  keytool -importkeystore \
    -srckeystore temp.p12 \
    -srcstoretype PKCS12 \
    -destkeystore $A_KEYSTORE \
    -srcalias $ALIAS \
    -destalias $ALIAS \
    -srcstorepass $B_PASSWORD \
    -deststorepass $A_PASSWORD \
    -noprompt

  # 3. 清理临时文件
  rm temp.p12

  echo "导入完成！"

  注意事项

  ⚠️ 重要：
  - 导入前建议先备份 A keystore
  - 如果 alias 已存在，使用 -noprompt 或 -keypass 覆盖
  - 确保两个 keystore 的密码设置正确
  - PKCS12 方式会同时导入私钥和证书，推荐使用
  - 只有私钥才能用于签名，纯证书只能用于验证
